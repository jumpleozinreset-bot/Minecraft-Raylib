const int WORLD_RADIUS = 1000;
const int SEA_LEVEL = 20;

enum GameState {
    STATE_LOBBY,
    STATE_SINGLEPLAYER_MENU,
    STATE_CREATE_WORLD,
    STATE_WORLD_LIST,
    STATE_MULTIPLAYER,
    STATE_LOADING,
    STATE_PAUSED,
    STATE_OPTIONS,
    STATE_GAME
};

enum BlockType {
    BLOCK_AIR = 0,
    BLOCK_BEDROCK,
    BLOCK_GRASS,
    BLOCK_DIRT,
    BLOCK_STONE,
    BLOCK_SAND,
    BLOCK_WATER,
    BLOCK_WOOD,
    BLOCK_LEAVES,
    BLOCK_STONE_BRICKS,
    BLOCK_GRAVEL,
    BLOCK_NUM_TYPES
};

struct BlockInfo {
    const char* name;
    const char* file;
    Color color;
};

static const BlockInfo BLOCKS[BLOCK_NUM_TYPES] = {
    {"Air", "", WHITE},
    {"Bedrock", "resource-packs/default/textures/bedrock.png", DARKGRAY},
    {"Grass", "resource-packs/default/textures/grass.png", GREEN},
    {"Dirt", "resource-packs/default/textures/dirt.png", BROWN},
    {"Stone", "resource-packs/default/textures/stone.png", LIGHTGRAY},
    {"Sand", "resource-packs/default/textures/sand.png", BEIGE},
    {"Water", "resource-packs/default/textures/water.png", SKYBLUE},
    {"Wood", "resource-packs/default/textures/wood.png", ORANGE},
    {"Leaves", "resource-packs/default/textures/leaves.png", LIME},
    {"Stone Bricks", "resource-packs/default/textures/stone_bricks.png", GRAY},
    {"Gravel", "resource-packs/default/textures/gravel.png", DARKGRAY}
};

struct WorldInfo {
    std::string name;
    bool creative;
    unsigned int seed;
};

struct ChunkCoord {
    int x;
    int z;
    bool operator==(ChunkCoord const& other) const { return x == other.x && z == other.z; }
};

struct ChunkHash {
    size_t operator()(ChunkCoord const& c) const noexcept {
        return ((uint64_t)(uint32_t)c.x << 32) ^ (uint32_t)c.z;
    }
};

using ChunkData = std::vector<uint8_t>;
static std::unordered_map<ChunkCoord, ChunkData, ChunkHash> chunks;
static Texture2D textures[BLOCK_NUM_TYPES] = {0};
